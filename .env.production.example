APP_NAME=GRMRL
APP_ENV=production
APP_KEY=base64:GENERATE_WITH_php_artisan_key_generate
APP_DEBUG=false
APP_URL=https://your-domain.it

APP_LOCALE=it
APP_FALLBACK_LOCALE=it
APP_FAKER_LOCALE=it_IT

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=grmrl
DB_USERNAME=grmrl
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_HOST=your-smtp-host
MAIL_PORT=587
MAIL_USERNAME=your-smtp-username
MAIL_PASSWORD=your-smtp-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@cai-lombardia.it"
MAIL_FROM_NAME="${APP_NAME}"

# Filament admin credentials
FILAMENT_ADMIN_EMAIL=admin@cai-lombardia.it
FILAMENT_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# GRMRL contact info
GRMRL_PHONE=+393274851177
GRMRL_EMAIL=gr_cai_lombardia@cai.it
GRMRL_SUPPORT_HOURS="Lun-Ven 9:00-18:00"

# Montagna Servizi support contacts (shown in header)
GRMRL_SUPPORT_PHONE="+39 02 555 555"
GRMRL_SUPPORT_EMAIL=grmrl@montagnaservizi.com

VITE_APP_NAME="${APP_NAME}"
